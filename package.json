{
  "name": "adversarial",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "adversary": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli/index.ts --compile --outfile dist/adversary",
    "build:linux-x64": "bun build src/cli/index.ts --compile --target=bun-linux-x64 --outfile dist/adversary-linux-x64",
    "build:linux-arm64": "bun build src/cli/index.ts --compile --target=bun-linux-arm64 --outfile dist/adversary-linux-arm64",
    "build:darwin-arm64": "bun build src/cli/index.ts --compile --target=bun-darwin-arm64 --outfile dist/adversary-darwin-arm64",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
